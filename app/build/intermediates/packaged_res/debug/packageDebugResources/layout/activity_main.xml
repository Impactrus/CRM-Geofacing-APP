<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/crm_surface"
    tools:context=".MainActivity">

    <!-- Top Navbar -->
    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height"
        android:background="@color/white"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/topbar_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:text="@string/title_dashboard"
            android:textColor="@color/crm_heading"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/topbar_avatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_initials_circle"
            android:gravity="center"
            android:text="JA"
            android:textColor="@color/status_success_text"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Permission Rationale (Visible when permission missing) -->
            <LinearLayout
                android:id="@+id/permission_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_profile_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Wymagane Uprawnienia"
                    android:textColor="@color/crm_heading"
                    android:textSize="15sp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/permission_rationale"
                    android:textColor="@color/crm_body"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btn_grant"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/button_small_height"
                    android:backgroundTint="@color/crm_primary"
                    android:text="@string/btn_grant"
                    android:textColor="@color/white"
                    app:cornerRadius="6dp" />
            </LinearLayout>

            <!-- Stats Card Container (2 Mini Cards) -->
            <LinearLayout
                android:id="@+id/stats_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_profile_card"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_total"
                            android:textColor="@color/crm_secondary"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/stat_total_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/crm_heading"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:text="0" />
                    </LinearLayout>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_phone"
                        app:tint="@color/crm_primary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_profile_card"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_missed"
                            android:textColor="@color/crm_secondary"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/stat_missed_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/status_error_text"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:text="0" />
                    </LinearLayout>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_phone"
                        app:tint="@color/crm_error" />
                </LinearLayout>
            </LinearLayout>

            <!-- Search bar -->
            <EditText
                android:id="@+id/search_bar"
                android:layout_width="match_parent"
                android:layout_height="@dimen/search_height"
                android:background="@drawable/bg_search_bar"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="8dp"
                android:hint="@string/search_hint"
                android:paddingHorizontal="12dp"
                android:textColor="@color/crm_heading"
                android:textColorHint="@color/crm_placeholder"
                android:textSize="@dimen/text_body"
                android:layout_marginBottom="12dp"
                android:inputType="text"
                android:maxLines="1" />

            <!-- Filter Tab Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_tab_bar"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="4dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tab_all"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_active"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="@string/filter_all"
                    android:textColor="@color/crm_body"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tab_incoming"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_inactive"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:text="@string/filter_incoming"
                    android:textColor="@color/crm_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tab_outgoing"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_inactive"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:text="@string/filter_outgoing"
                    android:textColor="@color/crm_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tab_missed"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_inactive"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:text="@string/filter_missed"
                    android:textColor="@color/crm_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Loading indicator -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            <!-- Empty State -->
            <TextView
                android:id="@+id/empty_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_calls"
                android:textColor="@color/crm_secondary"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone" />

            <!-- Recycler List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
