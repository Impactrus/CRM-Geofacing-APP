<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/crm_surface"
    tools:context=".MainActivity">

    <!-- Top Navbar -->
    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height"
        android:background="@color/white"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/topbar_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:text="Rejestr Połączeń"
            android:textColor="@color/crm_heading"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/topbar_avatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_initials_circle"
            android:gravity="center"
            android:text="JA"
            android:textColor="@color/status_success_text"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Bottom Navbar -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/nav_history"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground">
            <ImageView
                android:id="@+id/nav_history_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_phone"
                app:tint="@color/crm_primary" />
            <TextView
                android:id="@+id/nav_history_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Historia"
                android:textSize="11sp"
                android:textColor="@color/crm_primary"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_tasks"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground">
            <ImageView
                android:id="@+id/nav_tasks_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check"
                app:tint="@color/crm_secondary" />
            <TextView
                android:id="@+id/nav_tasks_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Zadania"
                android:textSize="11sp"
                android:textColor="@color/crm_secondary"
                android:fontFamily="sans-serif"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Content History Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_history_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topbar"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation">

        <!-- Content Layout for Stats, Search, Filters -->
        <LinearLayout
            android:id="@+id/header_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Permission Rationale -->
            <LinearLayout
                android:id="@+id/permission_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_profile_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Wymagane Uprawnienia"
                    android:textColor="@color/crm_heading"
                    android:textSize="15sp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/permission_rationale"
                    android:textColor="@color/crm_body"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btn_grant"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/button_small_height"
                    android:backgroundTint="@color/crm_primary"
                    android:text="@string/btn_grant"
                    android:textColor="@color/white"
                    app:cornerRadius="6dp" />
            </LinearLayout>

            <!-- Stats Card Container (2 Mini Cards) -->
            <LinearLayout
                android:id="@+id/stats_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_profile_card"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_total"
                            android:textColor="@color/crm_secondary"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/stat_total_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/crm_heading"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:text="0" />
                    </LinearLayout>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_phone"
                        app:tint="@color/crm_primary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_profile_card"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_missed"
                            android:textColor="@color/crm_secondary"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/stat_missed_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/crm_error"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:text="0" />
                    </LinearLayout>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_phone"
                        app:tint="@color/crm_error" />
                </LinearLayout>
            </LinearLayout>

            <!-- Search bar -->
            <EditText
                android:id="@+id/search_bar"
                android:layout_width="match_parent"
                android:layout_height="@dimen/search_height"
                android:background="@drawable/bg_search_bar"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="8dp"
                android:hint="@string/search_hint"
                android:paddingHorizontal="12dp"
                android:textColor="@color/crm_heading"
                android:textColorHint="@color/crm_placeholder"
                android:textSize="@dimen/text_body"
                android:layout_marginBottom="12dp"
                android:inputType="text"
                android:maxLines="1" />

            <!-- Filter Tab Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_tab_bar"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="4dp">

                <TextView
                    android:id="@+id/tab_all"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_active"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="@string/filter_all"
                    android:textColor="@color/crm_body"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tab_incoming"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_inactive"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:text="@string/filter_incoming"
                    android:textColor="@color/crm_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tab_outgoing"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_inactive"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:text="@string/filter_outgoing"
                    android:textColor="@color/crm_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tab_missed"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_inactive"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:text="@string/filter_missed"
                    android:textColor="@color/crm_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header_layout" />

        <!-- Empty State -->
        <TextView
            android:id="@+id/empty_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_calls"
            android:textColor="@color/crm_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/header_layout" />

        <!-- Recycler List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header_layout" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Content Tasks Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_tasks_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/topbar"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation">

        <!-- Stats and Button Area -->
        <LinearLayout
            android:id="@+id/tasks_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Stats Card Container for Tasks -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_profile_card"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="W toku"
                            android:textColor="@color/crm_secondary"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/stat_tasks_pending"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/status_warning_text"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:text="0" />
                    </LinearLayout>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_check"
                        app:tint="@color/status_warning_text" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_profile_card"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wykonane"
                            android:textColor="@color/crm_secondary"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/stat_tasks_completed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/status_success_text"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:text="0" />
                    </LinearLayout>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_check"
                        app:tint="@color/status_success_text" />
                </LinearLayout>
            </LinearLayout>

            <!-- Add Task Button -->
            <Button
                android:id="@+id/btn_add_task"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:backgroundTint="@color/crm_primary"
                android:text="Dodaj zadanie telefoniczne"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:cornerRadius="8dp" />
        </LinearLayout>

        <!-- Tasks Recycler View -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tasks_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tasks_header" />

        <!-- Tasks Empty State -->
        <TextView
            android:id="@+id/tasks_empty_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Brak zadań. Dodaj nowe zadanie za pomocą przycisku powyżej."
            android:textColor="@color/crm_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tasks_header" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
