<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@drawable/bg_card"
    android:layout_marginBottom="8dp">

    <!-- Avatar Initials / Icon Circle -->
    <TextView
        android:id="@+id/task_avatar_circle"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_initials_circle"
        android:gravity="center"
        android:text="Z"
        android:textColor="@color/status_success_text"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/task_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tytuł zadania"
            android:textStyle="bold"
            android:textColor="@color/crm_heading"
            android:textSize="15sp"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/task_contact_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kontakt • numer"
            android:textSize="12sp"
            android:textColor="@color/crm_secondary"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Right Side Status Badge, Date & Delete Button -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/task_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="W toku"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="@color/status_warning_text"
                android:background="@drawable/bg_tab_inactive" />

            <TextView
                android:id="@+id/task_completed_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="11sp"
                android:textColor="@color/crm_placeholder"
                android:layout_marginTop="4dp"
                android:visibility="gone" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_call_task"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:src="@drawable/ic_phone"
            app:tint="@color/crm_success"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Zadzwoń"
            android:layout_marginEnd="8dp" />

        <ImageView
            android:id="@+id/btn_delete_task"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:src="@drawable/ic_delete"
            app:tint="@color/crm_error"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Usuń zadanie" />
    </LinearLayout>

</LinearLayout>
