<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/crm_primary</item>
        <item name="colorPrimaryDark">@color/crm_primary_dark</item>
        <item name="colorAccent">@color/crm_blue</item>
        <item name="android:fitsSystemWindows">true</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Base class for text inheritance -->
    <style name="TextAppearance.Crm" parent="" />

    <style name="TextAppearance.Crm.Heading">
        <item name="android:textSize">@dimen/text_heading</item>
        <item name="android:textColor">@color/crm_heading</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Crm.Subheading">
        <item name="android:textSize">@dimen/text_subheading</item>
        <item name="android:textColor">@color/crm_heading</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Crm.Body">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/crm_body</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.Crm.Caption">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/crm_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.Crm.Button">
        <item name="android:textSize">@dimen/text_subheading</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
